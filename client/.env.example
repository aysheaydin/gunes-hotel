# ============================================
# Güneş Hotel - Client Environment Variables
# ============================================
# Copy this file to .env and update values

# ============================================
# API Configuration
# ============================================
# Backend API base URL
# Development: http://localhost:5000/api
# Production: https://yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# ============================================
# Application Configuration
# ============================================
VITE_APP_NAME=Güneş Hotel
VITE_APP_URL=https://www.nemrutgunesmotel.com

# ============================================
# Contact Information
# ============================================
VITE_PHONE_1=+905438767271
VITE_PHONE_2=+905362870639
VITE_EMAIL=gunesmotel@hotmail.com
VITE_WHATSAPP=905362870639

# ============================================
# Social Media (Optional)
# ============================================
# Uncomment and add your social media URLs
# VITE_FACEBOOK_URL=https://facebook.com/yourpage
# VITE_INSTAGRAM_URL=https://instagram.com/yourpage
# VITE_TWITTER_URL=https://twitter.com/yourpage
# VITE_LINKEDIN_URL=https://linkedin.com/company/yourpage

# ============================================
# Analytics & Tracking (Optional)
# ============================================
# Google Analytics 4
# Get from: https://analytics.google.com
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Google Tag Manager
# Get from: https://tagmanager.google.com
# VITE_GTM_ID=GTM-XXXXXXX

# Facebook Pixel
# VITE_FB_PIXEL_ID=

# ============================================
# Error Tracking (Optional)
# ============================================
# Sentry.io for error monitoring
# Get from: https://sentry.io
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# Feature Flags (Optional)
# ============================================
# VITE_ENABLE_PWA=true
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_CHAT_WIDGET=false

# ============================================
# Development Only
# ============================================
# VITE_DEBUG_MODE=false
# VITE_MOCK_API=false

