{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { 
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_" 
    }],
    "no-console": "off",
    "prefer-const": "error",
    "no-var": "error",
    "object-shorthand": "warn",
    "arrow-body-style": ["warn", "as-needed"],
    "prefer-arrow-callback": "warn",
    "prefer-template": "warn",
    "no-useless-concat": "warn",
    "prefer-destructuring": ["warn", {
      "array": false,
      "object": true
    }]
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "*.test.js"
  ]
}
