# ============================================
# Güneş Hotel - Server Environment Variables
# ============================================
# Copy this file to .env and update all values marked with YOUR_*

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Security Configuration
# ============================================
# CSRF Secret (REQUIRED - Change in production!)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CSRF_SECRET=YOUR_RANDOM_BASE64_STRING_HERE

# ============================================
# Email Configuration
# ============================================
# Email service provider (gmail, smtp, outlook, etc.)
EMAIL_SERVICE=gmail

# SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Email Credentials
# For Gmail: Create App Password at https://myaccount.google.com/security
# IMPORTANT: Never use your actual Gmail password!
EMAIL_USER=YOUR_EMAIL@gmail.com
EMAIL_PASSWORD=YOUR_APP_SPECIFIC_PASSWORD

# Sender information
EMAIL_FROM="Güneş Hotel <gunesmotel@hotmail.com>"

# ============================================
# Receiver Email Addresses
# ============================================
# Where contact form submissions go
CONTACT_EMAIL=gunesmotel@hotmail.com

# Where reservation requests go
RESERVATION_EMAIL=gunesmotel@hotmail.com

# ============================================
# CORS Configuration
# ============================================
# Allowed origins (comma-separated for multiple)
# Development: http://localhost:5173
# Production: https://www.nemrutgunesmotel.com,https://nemrutgunesmotel.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# Rate Limiting
# ============================================
# Time window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# IP Access Control (Optional)
# ============================================
# Comma-separated list of IPs to block
# Example: 192.168.1.1,10.0.0.1
BLOCKED_IPS=

# ============================================
# Logging Configuration
# ============================================
# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# ============================================
# Database (Optional - for future use)
# ============================================
# MongoDB connection string
# DB_CONNECTION_STRING=mongodb://localhost:27017/gunes-hotel

# Redis for session/cache (optional)
# REDIS_URL=redis://localhost:6379

# ============================================
# SMS/WhatsApp Notifications (Optional)
# ============================================
# For reservation notifications via SMS
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ============================================
# Payment Integration (Optional - for future)
# ============================================
# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# PayPal
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# ============================================
# Third-Party Services (Optional)
# ============================================
# Google Maps API (for location features)
# GOOGLE_MAPS_API_KEY=

# Google reCAPTCHA (for spam protection)
# RECAPTCHA_SECRET_KEY=

# Cloudinary (for image hosting)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ============================================
# Monitoring & Error Tracking (Optional)
# ============================================
# Sentry.io for error tracking
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# ============================================
# Notes for Production Deployment
# ============================================
# 1. Change NODE_ENV to 'production'
# 2. Generate strong CSRF_SECRET (min 32 characters)
# 3. Create Gmail App Password (not regular password)
# 4. Update CORS_ORIGIN to your production domain
# 5. Configure SSL/TLS for email if needed (EMAIL_SECURE=true)
# 6. Review and adjust rate limiting based on traffic
# 7. Set appropriate LOG_LEVEL (warn or error for production)
# 8. NEVER commit .env file to git!

