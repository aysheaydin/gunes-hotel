# Server Configuration
PORT=5000
NODE_ENV=development

# Security
CSRF_SECRET=your-csrf-secret-change-this-in-production-use-long-random-string

# Email Configuration (Gmail örneği)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM="Güneş Hotel <gunesmotel@hotmail.com>"

# Receiver Email
CONTACT_EMAIL=gunesmotel@hotmail.com
RESERVATION_EMAIL=rezervasyon@guneshotel.com

# CORS (Multiple origins separated by comma)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting (Optional - defaults are set in code)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# IP Access Control (Optional - comma separated IPs to block)
BLOCKED_IPS=

# Logging
LOG_LEVEL=info
